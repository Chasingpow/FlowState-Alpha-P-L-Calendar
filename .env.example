# =====================================================================
#  REQUIRED
# =====================================================================
POLYGON_API_KEY=your_polygon_key_here

# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel IDs (right-click channel in Discord -> Copy Channel ID;
# requires Developer Mode in Discord settings -> Advanced)
CHANNEL_SMALL=000000000000000000
CHANNEL_MID=000000000000000000

# =====================================================================
#  VOICE (optional but the whole point of v2)
# =====================================================================
# Voice channel the bot joins on startup. Set to 0 / leave blank to disable.
VOICE_CHANNEL_ID=000000000000000000

# Minimum grade at which the bot speaks the alert: A+, A, B, C, D
SPEAK_MIN_GRADE=A+

# Override bot display name (only takes effect if Discord allows the change)
BOT_DISPLAY_NAME=

# =====================================================================
#  TUNING (defaults shown)
# =====================================================================
POLL_INTERVAL_SEC=1.0
ALERT_COOLDOWN_SEC=1800        # 30 min between same-ticker re-alerts

# =====================================================================
#  P&L Calendar Web App
# =====================================================================
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback
SECRET_KEY=your_secret_key_here
FOLLOWUP_INTERVAL_SEC=300      # NHOD/momentum follow-up cadence
ALERT_MIN_GRADE=B              # A+, A, B, C, D — anything below this is silent
TOP_N=15                       # how many gainers tracked per band
MIN_GAIN_PCT=3.0               # ignore anything moving less than this
WATCHLIST_FILE=watchlist.txt
LOG_LEVEL=INFO

# =====================================================================
#  Top Gainers Board (pnl_calendar.py) — SEPARATE from scanner channels
# =====================================================================
# These are DIFFERENT channels from CHANNEL_SMALL / CHANNEL_MID above.
# Right-click your "small-cap-gainers" channel → Copy Channel ID
GAINERS_CHANNEL_SMALL=000000000000000000
# Right-click your "mid-cap-gainers" channel → Copy Channel ID
GAINERS_CHANNEL_MID=000000000000000000

# How often the background task refreshes data from Polygon (seconds)
GAINERS_REFRESH_SEC=45
# How often the leaderboard message is edited in Discord (seconds)
GAINERS_DISCORD_POST_SEC=300
